# OpenMonoAgent.ai — Hybrid MoE + TurboQuant environment
# Copy this to .env and customize for your hardware.
#
# Model: Qwen3.6-35B-A3B (MoE, 35B total / 3B active)
# Setup: openmono hybrid

# Model file (must be in models/ directory)
MODEL_NAME=Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf
MODEL_ALIAS=qwen3.6-35b-a3b

# Inference server port
LLAMA_PORT=7474

# Context window size (tokens)
CTX_SIZE=196608

# KV cache quantization type
#   turbo3  — ~3.5 bpv, ~4.6x compression (max memory savings)
#   turbo4  — ~4.25 bpv, ~3.8x compression (higher quality)
#   q8_0    — 8-bit baseline (no TurboQuant)
CACHE_K=turbo3
CACHE_V=turbo3

# API key (optional, generated by openmono tunnel rotate-key)
LLAMA_API_KEY=
