cmd_status() {
    echo ""

    if [[ "$NATIVE_INFERENCE" == "true" ]]; then
        native_cmd_status
    else
        _ensure_docker
        if ! docker info &>/dev/null 2>&1; then
            warn "Docker daemon is not accessible — cannot show status"
            if [ "$_OPENMONO_OS" = "Darwin" ]; then
                [ -d "/Applications/Docker.app" ] && warn "Try: open /Applications/Docker.app" \
                    || warn "Try: colima start"
            else
                warn "Try: sudo systemctl start docker"
            fi
            return 1
        fi

        echo -e "${BLUE}── Containers ───────────────────────────────────────${NC}"
        docker ps \
            --filter "name=llama-server" \
            --filter "name=openmono-agent" \
            --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || true

        echo ""
        echo -e "${BLUE}── llama-server health ──────────────────────────────${NC}"
        if curl -sf "http://localhost:${LLAMA_PORT}/health" &>/dev/null; then
            ok "http://localhost:${LLAMA_PORT}/health → OK"
        else
            warn "http://localhost:${LLAMA_PORT}/health → not responding"
        fi

        echo ""
        echo -e "${BLUE}── GPU ──────────────────────────────────────────────${NC}"
        if command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null 2>&1; then
            nvidia-smi \
                --query-gpu=name,memory.used,memory.total,utilization.gpu \
                --format=csv,noheader,nounits \
                | awk -F', ' '{printf "  %s  VRAM: %s/%s MiB  GPU: %s%%\n", $1, $2, $3, $4}'
        else
            HAS_HW=false
            if command -v lspci &>/dev/null && lspci 2>/dev/null | grep -qi 'nvidia'; then
                HAS_HW=true
            elif grep -qi "0x10de" /sys/bus/pci/devices/*/vendor 2>/dev/null; then
                HAS_HW=true
            fi
            if [ "$HAS_HW" = true ]; then
                echo -e "  ${YELLOW}⚠${NC}  NVIDIA hardware detected, but drivers not working/installed"
            elif grep -q "server-vulkan" "$DOCKER_DIR/docker-compose.override.yml" 2>/dev/null; then
                _AMD_GPU_NAME=$(lspci 2>/dev/null | grep -im1 'vga.*amd' | sed 's/.*: //' || true)
                echo "  AMD iGPU (Vulkan mode): ${_AMD_GPU_NAME:-amdgpu}"
                if grep -q "amdgpu.gttsize=" /proc/cmdline 2>/dev/null; then
                    _GTT_MB=$(grep -o "amdgpu.gttsize=[0-9]*" /proc/cmdline | cut -d= -f2)
                    echo "  GTT window: $(( _GTT_MB / 1024 ))GB system RAM available as VRAM"
                fi
            else
                echo "  No NVIDIA GPU detected"
            fi
        fi
    fi

    echo ""
    echo -e "${BLUE}── Model ────────────────────────────────────────────${NC}"
    # Strategy 1: query the running server (/props for llama.cpp, /v1/models for relays)
    LOADED=""
    LOADED=$(curl -sf --max-time 3 "http://localhost:${LLAMA_PORT}/props" \
        | python3 -c "
import sys, json
d = json.load(sys.stdin)
def basename(p): return p.split('/')[-1].replace('.gguf', '').replace('.GGUF', '') if p else ''
name = (d.get('model_alias') or '').strip() \
    or basename((d.get('model_path') or '').strip()) \
    or basename((d.get('default_generation_settings', {}).get('model') or '').strip())
print(name)
" 2>/dev/null || true)
    if [ -z "$LOADED" ]; then
        LOADED=$(curl -sf --max-time 3 "http://localhost:${LLAMA_PORT}/v1/models" \
            | python3 -c "
import sys, json
d = json.load(sys.stdin)
models = d.get('data', [])
print(models[0].get('id', '').strip() if models else '')
" 2>/dev/null || true)
    fi

    if [ -n "$LOADED" ]; then
        ok "Model loaded: $LOADED"
    else
        # Strategy 2: fall back to any .gguf on disk
        GGUF=$(find "$REPO_DIR/models" -maxdepth 1 -name "*.gguf" 2>/dev/null | head -1)
        if [ -n "$GGUF" ]; then
            SIZE=$(du -h "$GGUF" | cut -f1)
            ok "Model on disk: $(basename "$GGUF") ($SIZE)"
        else
            warn "Model not found — run: openmono setup"
        fi
    fi
    echo ""
}

cmd_model() {
    local models_dir="$REPO_DIR/models"
    local env_file="$DOCKER_DIR/.env"
    local sub="${1:-list}"

    if [[ "$sub" == "--help" || "$sub" == "-h" || "$sub" == "help" ]]; then
        echo "Usage: openmono model [list|use <name>] [--ctx N] [--ncmoe N|all|off]"
        echo ""
        echo "  list             List all models in $models_dir (default)"
        echo "  use <name>       Switch llama-server to a model. <name> can be the"
        echo "                   filename or any unambiguous part of it (case-insensitive)."
        echo "  --ctx N          Also set CTX_SIZE (context window) when switching."
        echo "  --ncmoe N|all|off  MoE expert CPU-offload. Auto by default: only offloads"
        echo "                   when a MoE model (…-A<n>B…) would NOT fit the GPU pool."
        echo "                   The AMD iGPU addresses ~96 GB of GTT, so nothing offloads"
        echo "                   there; a 16 GB card needs it. N = first N layers on CPU."
        echo "  --no-mtp         Disable MTP speculative decoding (auto-on for *-MTP-* models)."
        echo ""
        echo "Switching updates docker/.env (MODEL_NAME, MODEL_ALIAS, vision projector"
        echo "if a matching mmproj exists, MoE offload, MTP) and restarts llama-server."
        echo ""
        echo "Examples:"
        echo "  openmono model                       # list models"
        echo "  openmono model use glm-4.7           # switch by partial name"
        echo "  openmono model use ornith-1.0-9b --ctx 131072"
        return 0
    fi

    [[ -d "$models_dir" ]] || { err "Models directory not found: $models_dir"; exit 1; }

    # Candidate model files: all GGUFs except vision projectors; for sharded
    # models only the first shard (llama-server loads the rest automatically).
    local -a candidates=()
    local f base
    for f in "$models_dir"/*.gguf; do
        [[ -e "$f" ]] || continue
        base="$(basename "$f")"
        [[ "$base" == mmproj-* ]] && continue
        if [[ "$base" =~ -[0-9]{5}-of-[0-9]{5}\.gguf$ ]]; then
            [[ "$base" == *-00001-of-* ]] || continue
        fi
        candidates+=("$base")
    done
    [[ ${#candidates[@]} -gt 0 ]] || { err "No models found in $models_dir"; exit 1; }

    local current=""
    [[ -f "$env_file" ]] && current="$(grep '^MODEL_NAME=' "$env_file" 2>/dev/null | head -1 | cut -d= -f2-)"

    # Total size of a model incl. shards, human-readable
    _model_size() {
        local first="$models_dir/$1" pattern
        if [[ "$1" =~ ^(.*)-00001-of-([0-9]{5})\.gguf$ ]]; then
            pattern="$models_dir/${BASH_REMATCH[1]}-"*"-of-${BASH_REMATCH[2]}.gguf"
            du -ch $pattern 2>/dev/null | tail -1 | cut -f1
        else
            du -h "$first" 2>/dev/null | cut -f1
        fi
    }

    # Usable GPU memory in bytes, for deciding whether a model needs MoE offload.
    # On an AMD iGPU the dedicated VRAM is a stub (~1 GB) and the real pool is GTT
    # (system RAM lent to the GPU), so GTT + VRAM is the honest figure. A discrete
    # NVIDIA card reports its VRAM via nvidia-smi. 0 = unknown → never auto-offload.
    _gpu_mem_bytes() {
        local f gtt vram best=0 total
        for f in /sys/class/drm/card*/device/mem_info_gtt_total; do
            [[ -r "$f" ]] || continue
            gtt="$(cat "$f" 2>/dev/null || echo 0)"
            vram="$(cat "${f%gtt_total}vram_total" 2>/dev/null || echo 0)"
            total=$(( gtt + vram ))
            [[ "$total" -gt "$best" ]] && best="$total"
        done
        if [[ "$best" -eq 0 ]] && command -v nvidia-smi &>/dev/null; then
            total="$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1)"
            [[ "$total" =~ ^[0-9]+$ ]] && best=$(( total * 1048576 ))
        fi
        printf '%s' "$best"
    }

    if [[ "$sub" == "list" || "$sub" == "ls" ]]; then
        echo ""
        echo -e "${BLUE}── Models in $models_dir ──${NC}"
        local marker
        for base in "${candidates[@]}"; do
            marker="  "
            [[ "$base" == "$current" ]] && marker="${GREEN}▶ ${NC}"
            printf "  ${marker}%-70s %8s\n" "$base" "$(_model_size "$base")"
        done
        echo ""
        echo "  Switch with: openmono model use <name>"
        [[ -n "$current" ]] && echo "  Active model (docker/.env): $current"
        echo ""
        return 0
    fi

    # `openmono model use <name>` — also accept `openmono model <name>` shorthand
    [[ "$sub" == "use" ]] && shift
    local query="${1:-}"
    shift || true
    local new_ctx=""
    # MoE expert offload override: unset = auto (offload only if the model would
    # not fit the GPU pool), a number = experts of the first N layers, "all" =
    # every layer, "off" = none.  --no-mtp opts out of MTP speculative decoding.
    local moe_opt="" no_mtp=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ctx) new_ctx="${2:-}"; shift 2 ;;
            --ncmoe|--moe) moe_opt="${2:-}"; shift 2 ;;
            --cpu-moe) moe_opt="all"; shift ;;
            --no-moe|--no-cpu-moe) moe_opt="off"; shift ;;
            --no-mtp) no_mtp=true; shift ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done
    [[ -n "$query" ]] || { err "Usage: openmono model use <name>"; exit 1; }
    if [[ -n "$new_ctx" && ! "$new_ctx" =~ ^[0-9]+$ ]]; then
        err "--ctx expects a number (e.g. 131072)"; exit 1
    fi
    if [[ -n "$moe_opt" && "$moe_opt" != "all" && "$moe_opt" != "off" && ! "$moe_opt" =~ ^[0-9]+$ ]]; then
        err "--ncmoe expects a number, 'all' or 'off'"; exit 1
    fi

    # Resolve query → exactly one candidate (exact match wins, then substring)
    local -a matches=()
    local q_lc c_lc
    q_lc="$(echo "$query" | tr '[:upper:]' '[:lower:]')"
    for base in "${candidates[@]}"; do
        c_lc="$(echo "$base" | tr '[:upper:]' '[:lower:]')"
        [[ "$c_lc" == "$q_lc" || "$c_lc" == "$q_lc.gguf" ]] && { matches=("$base"); break; }
        [[ "$c_lc" == *"$q_lc"* ]] && matches+=("$base")
    done
    if [[ ${#matches[@]} -eq 0 ]]; then
        err "No model matches '$query'. Available:"
        printf '  %s\n' "${candidates[@]}" >&2
        exit 1
    elif [[ ${#matches[@]} -gt 1 ]]; then
        err "'$query' is ambiguous — matches:"
        printf '  %s\n' "${matches[@]}" >&2
        exit 1
    fi
    local model="${matches[0]}"

    # Alias: filename without .gguf and shard suffix, safe charset
    local alias="${model%.gguf}"
    alias="${alias%-00001-of-*}"
    alias="$(printf '%s' "$alias" | tr -c 'A-Za-z0-9._-' '-')"

    # Vision projector: use an mmproj whose core name (mmproj-<core>-F16.gguf)
    # is a prefix of the model filename; otherwise disable vision.
    local mmproj="" m core model_lc
    model_lc="$(echo "$model" | tr '[:upper:]' '[:lower:]')"
    for m in "$models_dir"/mmproj-*.gguf; do
        [[ -e "$m" ]] || continue
        core="$(basename "$m")"; core="${core#mmproj-}"; core="${core%.gguf}"
        core="$(echo "$core" | sed -E 's/-(bf16|f16|f32)$//I' | tr '[:upper:]' '[:lower:]')"
        # Generic names like mmproj-BF16.gguf leave an empty core after stripping —
        # an empty prefix would match EVERY model, so skip those.
        [[ -n "$core" ]] || continue
        [[ "$model_lc" == "$core"* ]] && { mmproj="$(basename "$m")"; break; }
    done

    # MoE expert offload. Models with an active-parameter signature (…-A<n>B…,
    # e.g. 35B-A3B, 26B-A4B) are Mixture-of-Experts. Offloading their experts to
    # CPU RAM (--cpu-moe) is what makes them fit a SMALL GPU — but it moves that
    # compute off the GPU, so it is a loss when the model already fits. Hence
    # auto-mode only offloads when the model would NOT fit the GPU pool:
    # the AMD iGPU addresses ~96 GB of GTT (everything fits, no offload), while a
    # 16 GB discrete card needs it for anything past ~14 GB.
    # --ncmoe N / --cpu-moe / --no-moe always override this.
    local moe_flags="" is_moe=false gpu_mem model_bytes
    [[ "$model" =~ -A[0-9]+B ]] && is_moe=true
    gpu_mem="$(_gpu_mem_bytes)"
    model_bytes="$(stat -c '%s' "$models_dir/$model" 2>/dev/null || echo 0)"
    case "$moe_opt" in
        off) moe_flags="" ;;
        all) moe_flags="--cpu-moe" ;;
        "")  if [[ "$is_moe" == true && "$gpu_mem" -gt 0 \
                  && "$model_bytes" -gt $(( gpu_mem * 85 / 100 )) ]]; then
                 moe_flags="--cpu-moe"
             fi ;;
        *)   moe_flags="--n-cpu-moe $moe_opt" ;;
    esac

    # Multi-token prediction: unsloth's "-MTP" GGUFs carry an MTP head, which
    # llama.cpp drives as self-speculative decoding (no separate draft model).
    # Without this flag the MTP weights are dead cargo.
    local spec_flags=""
    if [[ "$no_mtp" != "true" && "$model_lc" == *mtp* ]]; then
        spec_flags="--spec-type draft-mtp"
    fi

    # Rewrite docker/.env, preserving unrelated settings (same pattern as install.sh)
    touch "$env_file"
    grep -v -E "^MODEL_NAME=|^MODEL_ALIAS=|^MODEL_MMPROJ=|^MOE_FLAGS=|^SPEC_FLAGS=|^OPENMONO_VISION_ENABLED=${new_ctx:+|^CTX_SIZE=}" \
        "$env_file" > "${env_file}.tmp" || true
    {
        printf "MODEL_NAME=%s\nMODEL_ALIAS=%s\nMODEL_MMPROJ=%s\nOPENMONO_VISION_ENABLED=%s\n" \
            "$model" "$alias" "$mmproj" "$([ -n "$mmproj" ] && echo 1 || echo 0)"
        printf "MOE_FLAGS=%s\nSPEC_FLAGS=%s\n" "$moe_flags" "$spec_flags"
        [[ -n "$new_ctx" ]] && printf "CTX_SIZE=%s\n" "$new_ctx"
    } >> "${env_file}.tmp"
    mv "${env_file}.tmp" "$env_file"

    local ctx_now
    ctx_now="$(grep '^CTX_SIZE=' "$env_file" | head -1 | cut -d= -f2-)"
    ok "Model set: $model"
    detail "alias: $alias  ·  vision: ${mmproj:-off}  ·  moe-offload: ${moe_flags:-off (fits GPU)}  ·  mtp: $([ -n "$spec_flags" ] && echo on || echo off)  ·  ctx: ${ctx_now:-default}  ·  size: $(_model_size "$model")"

    # Large models leave less GTT room for the KV cache — hint, don't block.
    local bytes
    bytes="$(stat -c '%s' "$models_dir/$model" 2>/dev/null || echo 0)"
    if [[ "$bytes" -gt 42949672960 || "$model" == *-00001-of-* ]]; then
        warn "Large model — if it fails to load, lower the context first:"
        warn "  openmono model use $query --ctx 65536"
    fi

    if [[ "$NATIVE_INFERENCE" == "true" ]]; then
        info "Restart inference to apply: openmono restart"
        return 0
    fi

    _ensure_docker
    cd "$DOCKER_DIR"
    info "Restarting llama-server with $alias ..."
    docker compose up -d llama-server
    info "Waiting for llama-server to load the model (large models take a few minutes)..."
    local i
    for i in $(seq 1 60); do
        if curl -sf "http://localhost:${LLAMA_PORT}/health" &>/dev/null; then
            ok "llama-server is healthy — model '$alias' is live"
            return 0
        fi
        sleep 5
        printf "."
    done
    echo ""
    warn "llama-server not healthy yet — check progress with: openmono logs"
}

